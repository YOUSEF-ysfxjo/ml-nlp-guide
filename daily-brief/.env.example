# الدليل اليومي — إرسال بالبريد (مثل research_harvester)
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية.
# لا ترفع .env إلى GitHub — أضف الأسرار في Settings → Secrets (للـ Actions).

# البريد (Gmail: استخدم "كلمة مرور التطبيق" من حساب Google)
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENT=your@gmail.com

# مفتاح OpenAI (مطلوب لتوليد الدليل)
OPENAI_API_KEY=
